APP_NAME=ProContact
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=procontact
DB_USERNAME=procontact
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Idle session timeout: signs the user out after SESSION_IDLE_MINUTES of
# inactivity, after a SESSION_IDLE_GRACE_SECONDS modal countdown.
SESSION_IDLE_MINUTES=10
SESSION_IDLE_GRACE_SECONDS=60

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="contact@procontact.app"
MAIL_FROM_NAME="${APP_NAME}"
# Replies to outgoing mail go to this monitored inbox (Proton catch-all on procontact.app).
MAIL_REPLY_TO_ADDRESS="contact@procontact.app"
MAIL_REPLY_TO_NAME="ProContact Support"

# Resend (https://resend.com) — sending domain must be verified: procontact.app
RESEND_KEY=

VITE_APP_NAME="${APP_NAME}"

# Social Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Trusted proxy (set to * if behind reverse proxy)
TRUSTED_PROXIES=*

# Laravel Nightwatch (https://nightwatch.laravel.com)
# Token from your Nightwatch project. Leave NIGHTWATCH_ENABLED=false locally
# to disable the agent until a token is configured.
NIGHTWATCH_ENABLED=false
NIGHTWATCH_TOKEN=
